<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Tuner Pal — Working Prototype</title>
  <style>
    :root{
      --bg:#0e0f13; --card:#14161d; --card2:#1a1d27; --border:#23273a; --border2:#2d3247;
      --teal:#00d4aa; --red:#ff4d4d; --yellow:#ffc64a; --blue:#4d9fff;
      --text:#c8cfe0; --text2:#6b7594; --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --body: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--body);background:var(--bg);color:var(--text);min-height:100vh}
    nav{display:flex;align-items:center;justify-content:space-between;padding:0 18px;height:60px;background:var(--card);border-bottom:1px solid var(--border);position:sticky;top:0}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-mark{width:34px;height:34px;background:var(--teal);border-radius:8px;display:flex;align-items:center;justify-content:center}
    .logo-name{font-weight:900;letter-spacing:1.5px;color:#fff}
    .tabs{display:flex;gap:6px;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:4px}
    .tab{padding:7px 12px;border-radius:8px;font-size:13px;color:var(--text2);border:0;background:transparent;cursor:pointer}
    .tab.active{background:var(--card2);color:#fff;border:1px solid var(--border2)}
    .chip{display:flex;align-items:center;gap:10px;background:var(--card2);border:1px solid var(--border2);border-radius:10px;padding:8px 12px}
    .dot{width:7px;height:7px;background:var(--teal);border-radius:50%;box-shadow:0 0 10px var(--teal)}
    .container{max-width:1100px;margin:0 auto;padding:22px}
    .screen{display:none}
    .screen.active{display:block}
    .hero{max-width:820px;margin:22px auto;text-align:center}
    .hero h1{font-size:42px;line-height:1.05;color:#fff;margin-bottom:10px}
    .hero h1 span{color:var(--teal)}
    .hero p{color:var(--text2);line-height:1.6}
    .row{display:grid;grid-template-columns:1.3fr .7fr;gap:14px;margin-top:18px}
    @media (max-width:900px){.row{grid-template-columns:1fr}}
    .card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px}
    .drop{border:2px dashed var(--border2);border-radius:18px;padding:34px;text-align:center;cursor:pointer;background:var(--card);transition:.15s}
    .drop:hover{border-color:var(--teal);background:var(--card2)}
    .btn{background:var(--teal);color:#000;border:0;border-radius:10px;padding:10px 14px;font-weight:800;cursor:pointer}
    .btn.ghost{background:transparent;color:var(--text);border:1px solid var(--border2)}
    .muted{color:var(--text2)}
    .mono{font-family:var(--mono)}
    .kpi{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:12px}
    @media (max-width:900px){.kpi{grid-template-columns:repeat(2,1fr)}}
    .k{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:12px}
    .k .l{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--text2);font-weight:800}
    .k .v{margin-top:6px;font-size:22px;color:#fff;font-family:var(--mono)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:800;border:1px solid transparent}
    .pill.g{background:rgba(0,212,170,.12);color:var(--teal);border-color:rgba(0,212,170,.2)}
    .pill.y{background:rgba(255,198,74,.12);color:var(--yellow);border-color:rgba(255,198,74,.2)}
    .pill.r{background:rgba(255,77,77,.12);color:var(--red);border-color:rgba(255,77,77,.2)}
    .issues{display:flex;flex-direction:column;gap:10px}
    .issue{background:var(--card2);border:1px solid var(--border);border-radius:14px;padding:12px}
    .issue h4{font-size:14px;color:#fff;margin-bottom:5px}
    .issue p{font-size:13px;line-height:1.55;color:var(--text2)}
    table{width:100%;border-collapse:collapse;margin-top:10px;border:1px solid var(--border);border-radius:14px;overflow:hidden}
    thead th{background:var(--card2);color:var(--text2);font-size:11px;letter-spacing:1px;text-transform:uppercase;padding:10px;border-bottom:1px solid var(--border);text-align:left}
    tbody td{padding:9px;border-bottom:1px solid rgba(35,39,58,.6);font-family:var(--mono);font-size:12px;color:var(--text2)}
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .rightActions{display:flex;gap:8px;flex-wrap:wrap}
    .notice{font-size:12px;color:var(--text2);line-height:1.6}
    .history{display:flex;flex-direction:column;gap:8px}
    .histItem{display:flex;justify-content:space-between;gap:10px;align-items:center;background:var(--card2);border:1px solid var(--border);border-radius:12px;padding:10px}
  </style>
</head>
<body>
  <nav>
    <div class="logo">
      <div class="logo-mark">🔧</div>
      <div class="logo-name">TUNER <span style="color:var(--teal)">PAL</span> — Prototype</div>
    </div>
    <div class="tabs">
      <button class="tab active" data-tab="upload">📂 Upload</button>
      <button class="tab" data-tab="results" disabled title="Upload a log first">📊 Analysis</button>
      <button class="tab" data-tab="history">🗂️ My Tunes</button>
    </div>
    <div class="chip">
      <div class="dot"></div>
      <div>
        <div style="font-weight:700;color:#fff;font-size:13px">Car Profile (prototype)</div>
        <div class="mono muted" style="font-size:11px">Make/Model · Stage · Fuel</div>
      </div>
    </div>
  </nav>

  <div class="container">
    <!-- UPLOAD -->
    <section class="screen active" id="screen-upload">
      <div class="hero">
        <h1>ANALYZE YOUR<br><span>TUNE IN SECONDS</span></h1>
        <p>Upload a datalog CSV. This prototype parses key columns and generates a “Tuner Pal” issue report.</p>
      </div>

      <div class="card">
        <div id="drop" class="drop">
          <div style="font-size:40px;margin-bottom:10px">📂</div>
          <div style="font-weight:900;color:#fff;font-size:18px;margin-bottom:6px">DROP YOUR DATALOG</div>
          <div class="muted" style="margin-bottom:14px">Drag & drop a CSV here, or click to browse</div>
          <button class="btn" id="chooseBtn">Choose File</button>
          <div class="mono" style="margin-top:12px;font-size:11px;color:#3b4567">
            Supported: Any CSV with RPM + (AFR/Lambda) + (Boost/Map) + (Timing) + (Knock/KR) when available
          </div>
          <input id="file" type="file" accept=".csv,text/csv" style="display:none" />
        </div>
      </div>

      <div class="card" style="margin-top:14px">
        <div style="font-weight:800;color:#fff;margin-bottom:8px">Quick Test (no log?)</div>
        <div class="notice">Click to load a built-in sample log so you can see the full flow immediately.</div>
        <div style="margin-top:10px;display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn" id="loadSample">Load Sample Log</button>
          <button class="btn ghost" id="clearHistory">Clear Saved History</button>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section class="screen" id="screen-results">
      <div class="card">
        <div class="topbar">
          <div>
            <div class="mono" style="color:var(--teal);font-weight:800" id="fileName">—</div>
            <div class="muted" style="font-size:12px;margin-top:3px" id="fileMeta">—</div>
          </div>
          <div class="rightActions">
            <button class="btn ghost" id="newLog">⬅ New Log</button>
            <button class="btn" id="exportJson">⬇ Export JSON Report</button>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="card">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
            <div style="font-weight:900;color:#fff;font-size:18px">Tune Health</div>
            <div id="healthPill" class="pill y">—</div>
          </div>

          <div class="kpi">
            <div class="k"><div class="l">Health Score</div><div class="v" id="score">—</div></div>
            <div class="k"><div class="l">Knock Events</div><div class="v" id="knockCount">—</div></div>
            <div class="k"><div class="l">AFR / Lambda Flags</div><div class="v" id="afrFlags">—</div></div>
            <div class="k"><div class="l">Boost Flags</div><div class="v" id="boostFlags">—</div></div>
          </div>

          <div style="margin-top:14px;font-weight:900;color:#fff">AI Findings (prototype)</div>
          <div class="issues" style="margin-top:10px" id="issues"></div>

          <div style="margin-top:14px" class="notice">
            Note: This is a prototype heuristic engine (rule-based). In the MVP, these findings come from your AI model using the normalized log + car context.
          </div>
        </div>

        <div class="card">
          <div style="font-weight:900;color:#fff;margin-bottom:8px">Detected Columns</div>
          <div class="notice" id="cols">—</div>
          <div style="height:12px"></div>
          <div style="font-weight:900;color:#fff;margin-bottom:8px">Next Action</div>
          <div class="notice">
            If this report is useful, you’re ready to:
            <br/>1) Add login + storage (Supabase)
            <br/>2) Add payments (Stripe)
            <br/>3) Replace heuristics with AI JSON output
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:14px">
        <div style="font-weight:900;color:#fff;margin-bottom:8px">Parsed Sample Rows (first 20)</div>
        <div style="overflow:auto">
          <table>
            <thead><tr id="thead"></tr></thead>
            <tbody id="tbody"></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- HISTORY -->
    <section class="screen" id="screen-history">
      <div class="card">
        <div style="font-weight:900;color:#fff;font-size:18px;margin-bottom:6px">My Tunes (prototype)</div>
        <div class="notice">Your last 10 reports are saved locally in this browser (localStorage).</div>
      </div>
      <div class="card" style="margin-top:14px">
        <div class="history" id="historyList"></div>
      </div>
    </section>
  </div>

<script>
  // ---------- Tabs ----------
  const tabs = document.querySelectorAll(".tab");
  const screens = {
    upload: document.getElementById("screen-upload"),
    results: document.getElementById("screen-results"),
    history: document.getElementById("screen-history"),
  };
  function go(tab){
    tabs.forEach(t => t.classList.toggle("active", t.dataset.tab === tab));
    Object.keys(screens).forEach(k => screens[k].classList.toggle("active", k === tab));
  }
  tabs.forEach(t => t.addEventListener("click", () => {
    if (t.disabled) return;
    go(t.dataset.tab);
    if (t.dataset.tab === "history") renderHistory();
  }));

  // ---------- Upload ----------
  const drop = document.getElementById("drop");
  const fileInput = document.getElementById("file");
  document.getElementById("chooseBtn").onclick = (e)=>{ e.preventDefault(); fileInput.click(); };
  drop.addEventListener("click", ()=>fileInput.click());
  drop.addEventListener("dragover", (e)=>{ e.preventDefault(); drop.style.borderColor = "var(--teal)"; });
  drop.addEventListener("dragleave", ()=>{ drop.style.borderColor = "var(--border2)"; });
  drop.addEventListener("drop", (e)=>{
    e.preventDefault(); drop.style.borderColor = "var(--border2)";
    const f = e.dataTransfer.files?.[0];
    if (f) handleFile(f);
  });
  fileInput.addEventListener("change", ()=>{
    const f = fileInput.files?.[0];
    if (f) handleFile(f);
  });

  document.getElementById("newLog").onclick = ()=>{
    go("upload");
    fileInput.value = "";
  };

  // ---------- Sample ----------
  document.getElementById("loadSample").onclick = ()=>{
    const csv = makeSampleCSV();
    analyzeCSV(csv, "SAMPLE_LOG.csv");
  };

  // ---------- History ----------
  const HISTORY_KEY = "tunerpal_history_v1";
  function loadHistory(){
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || "[]"); }
    catch { return []; }
  }
  function saveHistory(entry){
    const h = loadHistory();
    h.unshift(entry);
    const clipped = h.slice(0, 10);
    localStorage.setItem(HISTORY_KEY, JSON.stringify(clipped));
  }
  document.getElementById("clearHistory").onclick = ()=>{
    localStorage.removeItem(HISTORY_KEY);
    alert("History cleared.");
  };
  function renderHistory(){
    const list = document.getElementById("historyList");
    const h = loadHistory();
    list.innerHTML = "";
    if (!h.length){
      list.innerHTML = `<div class="notice">No saved reports yet. Upload a log first.</div>`;
      return;
    }
    h.forEach((x, idx)=>{
      const div = document.createElement("div");
      div.className = "histItem";
      div.innerHTML = `
        <div>
          <div style="font-weight:800;color:#fff">${x.fileName}</div>
          <div class="mono muted" style="font-size:11px">${new Date(x.createdAt).toLocaleString()} · score ${x.report.score} · issues ${x.report.issues.length}</div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn ghost" data-open="${idx}">Open</button>
          <button class="btn" data-dl="${idx}">JSON</button>
        </div>
      `;
      list.appendChild(div);
    });

    list.querySelectorAll("button[data-open]").forEach(btn=>{
      btn.onclick = ()=>{
        const idx = Number(btn.dataset.open);
        const entry = loadHistory()[idx];
        hydrateResults(entry.fileName, entry.meta, entry.report, entry.previewTable, entry.detected);
        enableResultsTab();
        go("results");
      };
    });
    list.querySelectorAll("button[data-dl]").forEach(btn=>{
      btn.onclick = ()=>{
        const idx = Number(btn.dataset.dl);
        const entry = loadHistory()[idx];
        downloadJSON(entry.report, entry.fileName.replace(".csv","") + "_report.json");
      };
    });
  }

  // ---------- Core File Handling ----------
  async function handleFile(file){
    if (!file.name.toLowerCase().endsWith(".csv")){
      alert("Please upload a .csv file.");
      return;
    }
    const text = await file.text();
    analyzeCSV(text, file.name);
  }

  function analyzeCSV(csvText, fileName){
    const parsed = parseCSV(csvText);
    if (!parsed.headers.length || parsed.rows.length < 5){
      alert("Could not parse CSV (needs headers + rows).");
      return;
    }
    const detected = detectColumns(parsed.headers);
    const norm = normalizeRows(parsed.rows, detected);

    const meta = {
      rows: norm.length,
      durationGuess: estimateDurationSeconds(norm, detected) // optional guess if time column exists
    };

    const report = generateReport(norm, detected);
    const previewTable = buildPreviewTable(norm, detected, 20);

    // save
    saveHistory({
      fileName,
      createdAt: Date.now(),
      meta,
      detected,
      report,
      previewTable
    });

    hydrateResults(fileName, meta, report, previewTable, detected);
    enableResultsTab();
    go("results");
  }

  function enableResultsTab(){
    const rtab = Array.from(tabs).find(t=>t.dataset.tab==="results");
    rtab.disabled = false;
    rtab.title = "";
  }

  // ---------- CSV Parse (simple, robust enough for prototype) ----------
  function parseCSV(text){
    // Handles: commas, quotes; assumes first row is header
    const lines = text.replace(/\r/g,"").split("\n").filter(Boolean);
    const headers = splitCSVLine(lines[0]).map(h=>h.trim());
    const rows = [];
    for (let i=1; i<lines.length; i++){
      const cols = splitCSVLine(lines[i]);
      if (cols.length === 1 && cols[0].trim()==="") continue;
      const obj = {};
      headers.forEach((h, idx)=> obj[h] = (cols[idx] ?? "").trim());
      rows.push(obj);
    }
    return { headers, rows };
  }
  function splitCSVLine(line){
    const out = [];
    let cur = "", inQ = false;
    for (let i=0; i<line.length; i++){
      const ch = line[i];
      if (ch === '"' ){
        if (inQ && line[i+1] === '"'){ cur += '"'; i++; }
        else inQ = !inQ;
      } else if (ch === "," && !inQ){
        out.push(cur); cur="";
      } else {
        cur += ch;
      }
    }
    out.push(cur);
    return out;
  }

  // ---------- Column Detection ----------
  function detectColumns(headers){
    const h = headers.map(x=>x.toLowerCase());
    const find = (cands)=> {
      for (const cand of cands){
        const idx = h.findIndex(x=>x === cand || x.includes(cand));
        if (idx>=0) return headers[idx];
      }
      return null;
    };
    return {
      rpm: find(["rpm","engine speed"]),
      time: find(["time","seconds","sec","timestamp"]),
      boost: find(["boost","map","manifold pressure","psi","kpa"]),
      afr: find(["afr","air/fuel","air fuel","lambda"]),
      knock: find(["knock","kr","knock retard","correction"]),
      timing: find(["timing","spark","ignition"]),
      iat: find(["iat","intake air","intake temp"]),
      throttle: find(["throttle","tps","throttle position"]),
    };
  }

  function toNum(v){
    if (v === null || v === undefined) return null;
    const n = Number(String(v).replace(/[^\d.\-]/g,""));
    return Number.isFinite(n) ? n : null;
  }

  function normalizeRows(rows, detected){
    // produce standard numeric fields; keep original row too
    return rows.map(r=>{
      const o = { _raw:r };
      o.rpm = detected.rpm ? toNum(r[detected.rpm]) : null;
      o.time = detected.time ? toNum(r[detected.time]) : null;
      o.boost = detected.boost ? toNum(r[detected.boost]) : null;
      o.afr = detected.afr ? toNum(r[detected.afr]) : null;
      o.knock = detected.knock ? toNum(r[detected.knock]) : null;
      o.timing = detected.timing ? toNum(r[detected.timing]) : null;
      o.iat = detected.iat ? toNum(r[detected.iat]) : null;
      o.throttle = detected.throttle ? toNum(r[detected.throttle]) : null;
      return o;
    }).filter(x=>x.rpm !== null || x.time !== null); // keep meaningful rows
  }

  function estimateDurationSeconds(norm, detected){
    if (!detected.time) return null;
    const times = norm.map(r=>r.time).filter(x=>typeof x==="number");
    if (!times.length) return null;
    return Math.max(...times) - Math.min(...times);
  }

  // ---------- Report Engine (prototype heuristics) ----------
  function generateReport(norm, detected){
    const issues = [];
    let score = 100;

    const rpm = norm.map(r=>r.rpm).filter(n=>Number.isFinite(n));
    const maxRpm = rpm.length ? Math.max(...rpm) : null;

    // Knock detection
    let knockEvents = 0;
    if (detected.knock){
      const k = norm.map(r=>r.knock).filter(n=>Number.isFinite(n));
      // count events > 2.0 (rough) OR any negative timing correction interpreted as "knock"
      knockEvents = k.filter(v=>v >= 2.0).length;
      if (knockEvents >= 3){
        score -= 18;
        issues.push({
          severity:"high",
          title:`Knock events detected (${knockEvents})`,
          body:`This log shows multiple knock/retard events. Re-check fueling and timing at the RPM/load where it occurs.`,
          fix:`Reduce timing in the affected region, verify fuel quality, check plugs/heat range, and confirm AFR targets under load.`
        });
      } else if (knockEvents >= 1){
        score -= 8;
        issues.push({
          severity:"medium",
          title:`Minor knock activity (${knockEvents})`,
          body:`A small number of knock events were detected. Could be noise or borderline timing.`,
          fix:`Review the exact RPM/load window. If repeatable, pull 1–2° timing there and retest.`
        });
      }
    }

    // AFR/Lambda flags
    let afrFlags = 0;
    if (detected.afr){
      const afr = norm.map(r=>r.afr).filter(n=>Number.isFinite(n));
      // rough heuristics: AFR too lean/rich if in AFR scale; if lambda scale, typical values near 1.0
      // We'll guess scale: if avg < 2 -> lambda; else AFR.
      const avg = afr.reduce((a,b)=>a+b,0) / (afr.length || 1);
      const isLambda = avg > 0 && avg < 2.5;

      if (isLambda){
        const lean = afr.filter(v=>v > 1.08).length;
        const rich = afr.filter(v=>v < 0.78).length;
        afrFlags = lean + rich;
        if (lean > 20){
          score -= 14;
          issues.push({
            severity:"high",
            title:`Lean lambda trend (>${1.08})`,
            body:`Lambda rises above safe targets for a meaningful portion of the log.`,
            fix:`Verify fuel pressure, injector duty, commanded lambda, and MAF scaling. Do not continue hard pulls until corrected.`
          });
        } else if (lean > 5){
          score -= 7;
          issues.push({
            severity:"medium",
            title:`Some lean spikes`,
            body:`Short lean spikes are present. Could be transient fueling or sensor noise.`,
            fix:`Check tip-in enrichment, sensor calibration, and repeat logging to confirm.`
          });
        }
      } else {
        const lean = afr.filter(v=>v > 13.2).length; // rough gasoline lean under load
        const rich = afr.filter(v=>v < 10.2).length;
        afrFlags = lean + rich;
        if (lean > 20){
          score -= 14;
          issues.push({
            severity:"high",
            title:`Lean AFR trend (>13.2)`,
            body:`AFR appears lean for a meaningful portion of the log (if this was under load).`,
            fix:`Confirm WOT AFR target, check fuel system, and verify sensor placement/reading.`
          });
        }
      }
    }

    // Boost flags
    let boostFlags = 0;
    if (detected.boost){
      const boost = norm.map(r=>r.boost).filter(n=>Number.isFinite(n));
      if (boost.length){
        const maxB = Math.max(...boost);
        const minB = Math.min(...boost);
        // very rough: flag if big oscillation
        if ((maxB - minB) > 8){
          boostFlags += 1;
          score -= 6;
          issues.push({
            severity:"medium",
            title:`Boost instability`,
            body:`Boost appears to swing significantly. This can indicate control issues or wastegate problems.`,
            fix:`Review WGDC/boost control, check for leaks, verify wastegate hardware and boost targets.`
          });
        }
      }
    }

    // Timing drops
    if (detected.timing){
      const t = norm.map(r=>r.timing).filter(n=>Number.isFinite(n));
      if (t.length){
        const maxT = Math.max(...t);
        const minT = Math.min(...t);
        if ((maxT - minT) > 12){
          score -= 5;
          issues.push({
            severity:"low",
            title:`Timing variation`,
            body:`Ignition timing varies widely. Could be normal across RPM/load, or may indicate timing pull.`,
            fix:`Check timing vs knock/iat. If timing drops coincide with knock/IAT, address those first.`
          });
        }
      }
    }

    // If no issues detected
    if (!issues.length){
      issues.push({
        severity:"good",
        title:"No major red flags detected",
        body:"This log looks stable based on the columns we found. For deeper confidence, add more channels (fuel pressure, WGDC, trims).",
        fix:"Run a consistent pull (same gear/conditions) and compare trend logs over time."
      });
    }

    // clamp score
    score = Math.max(35, Math.min(100, Math.round(score)));

    const tier = score >= 85 ? "green" : score >= 70 ? "yellow" : "red";
    return {
      version: "prototype-v1",
      createdAt: new Date().toISOString(),
      score,
      tier,
      summary: {
        maxRpm,
        knockEvents,
        afrFlags,
        boostFlags
      },
      issues
    };
  }

  // ---------- UI Hydration ----------
  function hydrateResults(fileName, meta, report, previewTable, detected){
    document.getElementById("fileName").textContent = fileName;
    const dur = meta.durationGuess ? `${Math.round(meta.durationGuess)}s (est)` : "—";
    document.getElementById("fileMeta").textContent = `${meta.rows.toLocaleString()} rows · duration ${dur}`;

    document.getElementById("score").textContent = report.score;
    document.getElementById("knockCount").textContent = report.summary.knockEvents ?? "—";
    document.getElementById("afrFlags").textContent = report.summary.afrFlags ?? "—";
    document.getElementById("boostFlags").textContent = report.summary.boostFlags ?? "—";

    const pill = document.getElementById("healthPill");
    pill.className = "pill " + (report.tier === "green" ? "g" : report.tier === "red" ? "r" : "y");
    pill.textContent = report.tier === "green" ? "✅ GOOD" : report.tier === "red" ? "🛑 NEEDS ATTENTION" : "⚠️ GOOD WITH ISSUES";

    const issuesEl = document.getElementById("issues");
    issuesEl.innerHTML = "";
    report.issues.forEach(i=>{
      const sev = i.severity === "high" ? "r" : i.severity === "medium" ? "y" : "g";
      const div = document.createElement("div");
      div.className = "issue";
      div.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">
          <h4>${i.title}</h4>
          <span class="pill ${sev}">${i.severity.toUpperCase()}</span>
        </div>
        <p style="margin-top:6px">${i.body}</p>
        <p style="margin-top:8px"><span style="color:#fff;font-weight:800">Fix:</span> ${i.fix}</p>
      `;
      issuesEl.appendChild(div);
    });

    document.getElementById("cols").innerHTML = `
      <div class="mono">
        rpm: <b>${detected.rpm || "—"}</b><br/>
        boost: <b>${detected.boost || "—"}</b><br/>
        afr/lambda: <b>${detected.afr || "—"}</b><br/>
        knock: <b>${detected.knock || "—"}</b><br/>
        timing: <b>${detected.timing || "—"}</b><br/>
        iat: <b>${detected.iat || "—"}</b><br/>
        throttle: <b>${detected.throttle || "—"}</b><br/>
        time: <b>${detected.time || "—"}</b>
      </div>
    `;

    renderTable(previewTable);
    wireExport(report, fileName);
  }

  function buildPreviewTable(norm, detected, n=20){
    // choose columns to display
    const cols = ["rpm","boost","afr","knock","timing","iat","throttle","time"].filter(c=>detected[c] || c==="rpm");
    const rows = norm.slice(0,n).map(r=>{
      const o = {};
      cols.forEach(c=> o[c] = r[c]);
      return o;
    });
    return { cols, rows };
  }

  function renderTable(preview){
    const thead = document.getElementById("thead");
    const tbody = document.getElementById("tbody");
    thead.innerHTML = "";
    tbody.innerHTML = "";

    preview.cols.forEach(c=>{
      const th = document.createElement("th");
      th.textContent = c.toUpperCase();
      thead.appendChild(th);
    });

    preview.rows.forEach(r=>{
      const tr = document.createElement("tr");
      preview.cols.forEach(c=>{
        const td = document.createElement("td");
        const v = r[c];
        td.textContent = (v === null || v === undefined) ? "" : String(v);
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
  }

  function wireExport(report, fileName){
    document.getElementById("exportJson").onclick = ()=>{
      downloadJSON(report, fileName.replace(".csv","") + "_report.json");
    };
  }

  function downloadJSON(obj, name){
    const blob = new Blob([JSON.stringify(obj,null,2)], {type:"application/json"});
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = name;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  // ---------- Sample Data ----------
  function makeSampleCSV(){
    // simple synthetic log with knock + afr lean segments
    const headers = ["Time","RPM","BoostPsi","AFR","KnockRetard","TimingDeg","IAT_F","Throttle"];
    const rows = [];
    let t=0;
    for (let i=0;i<260;i++){
      t += 0.1;
      const rpm = 1800 + i*18;
      const boost = Math.max(0, -2 + (i/260)*18 + (Math.sin(i/10)*1.2));
      const throttle = i<30 ? 25 : 85 + Math.sin(i/20)*5;
      let afr = 14.7 - (i/260)*3.5 + Math.sin(i/14)*0.2;
      // lean section
      if (i>160 && i<190) afr += 1.2;
      // knock events
      let kr = 0;
      if (i===175 || i===178 || i===182) kr = 3.2;
      const timing = 12 + (i/260)*10 - (kr>0 ? 4 : 0) - (boost>15 ? 2 : 0);
      const iat = 85 + (i/260)*25;
      rows.push([t.toFixed(2), Math.round(rpm), boost.toFixed(2), afr.toFixed(2), kr.toFixed(1), timing.toFixed(1), iat.toFixed(0), throttle.toFixed(0)].join(","));
    }
    return [headers.join(","), ...rows].join("\n");
  }

  // ---------- Export last report from history (if user wants) ----------
  // (Handled by button wiring; results are hydrated from current report.)
</script>
